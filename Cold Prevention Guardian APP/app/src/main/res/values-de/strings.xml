    <!-- DeepSeek API System Prompt -->
    <string name="deepseek_system_prompt">Sie sind ein professioneller Erkältungsschutz-Assistent. Basierend auf den Informationen des Benutzers geben Sie professionelle Ratschläge zu Symptomanalyse, möglichen Ursachen, Vorsichtsmaßnahmen und Präventionstipps. Falls Medikamente erwähnt werden, betonen Sie die Notwendigkeit, einen Arzt zu konsultieren. Antworten Sie in der Sprache, die der Benutzer verwendet.</string>

    <!-- Health Assessment Texts -->
    <string name="health_title_normal">Normale Temperatur</string>
    <string name="health_analysis_normal">Das Immunsystem ist in einem stabilen Zustand; keine Anzeichen von Fieber festgestellt.</string>
    <string name="health_causes_normal">Die aktuelle Temperatur liegt im normalen Bereich. Kein Grund zur Sorge.</string>
    <string name="health_complications_normal">Kein signifikantes Komplikationsrisiko.</string>
    <string name="health_advice_normal">Achten Sie auf gute Hygiene, waschen Sie häufig die Hände und halten Sie sich warm.</string>

    <string name="health_title_mild">Leicht erhöhte Temperatur</string>
    <string name="health_analysis_mild">Das Immunsystem hat eine Reaktion eingeleitet; leichte Entzündungen können vorhanden sein.</string>
    <string name="health_causes_mild">Kann auf eine saisonale Erkältung, eine Impfreaktion oder eine leichte Infektion zurückzuführen sein.</string>
    <string name="health_complications_mild">Wenn nicht kontrolliert, kann die Temperatur weiter ansteigen.</string>
    <string name="health_advice_mild">Symptomatische Behandlung wird empfohlen. Ruhen Sie sich aus, trinken Sie viel Wasser und überwachen Sie die Temperatur genau.</string>

    <string name="health_title_fever">Hohes Fieber / Verdacht auf Grippe</string>
    <string name="health_analysis_fever">Plötzliches hohes Fieber – das Immunsystem ist in einem Zustand aktiver Abwehr.</string>
    <string name="health_causes_fever">Starker Verdacht auf Influenzavirus oder bakterielle Infektion.</string>
    <string name="health_complications_fever">Anhaltend hohes Fieber kann zu Dehydrierung, Elektrolytstörungen oder Fieberkrämpfen führen.</string>
    <string name="health_advice_fever">Verwenden Sie KEIN kaltes Wasser oder Alkohol zur physikalischen Kühlung. Trinken Sie viel warmes Wasser. Kontaktieren Sie sofort einen Arzt, um zu prüfen, ob eine antivirale Behandlung erforderlich ist.</string>

    <string name="health_title_emergency">Notfall-Hyperpyrexie</string>
    <string name="health_analysis_emergency">Die Kerntemperatur ist deutlich erhöht; der Körper befindet sich in einem Hochrisiko-Stresszustand.</string>
    <string name="health_causes_emergency">Schwere Infektion, Hitzschlag oder andere akute pathologische Faktoren.</string>
    <string name="health_complications_emergency">Es besteht das Risiko von Organschäden; Notfallbehandlung ist erforderlich.</string>
    <string name="health_advice_emergency">Suchen Sie sofort medizinische Notfallhilfe! Halten Sie den Patienten während des Wartens auf Hilfe belüftet und überwachen Sie weiterhin die Temperatur.</string>

    <!-- Medication Texts -->
    <string name="med_name_vitamin_d3">Vitamin D3</string>
    <string name="med_region_global">Weltweit verfügbar</string>
    <string name="med_desc_vitamin_d3">Unterstützt die Immunfunktion und reduziert das Risiko von Atemwegsinfektionen.</string>

    <string name="med_name_echinacea">Echinacea (Sonnenhut)</string>
    <string name="med_region_eu_us">In Europa &amp; USA verbreitet</string>
    <string name="med_desc_echinacea">Pflanzlicher Immunbooster, der helfen kann, die Dauer von Erkältungen zu verkürzen.</string>

    <string name="med_name_paracetamol">Paracetamol</string>
    <string name="med_desc_paracetamol">Antipyretikum und Analgetikum zur Fiebersenkung und Linderung von Kopf- und Muskelschmerzen.</string>
    <string name="med_warning_paracetamol">Nicht mehr als 4 Dosen in 24 Stunden. Mindestens 4 Stunden zwischen den Dosen einhalten.</string>

    <string name="med_name_guaifenesin">Guaifenesin</string>
    <string name="med_desc_guaifenesin">Expektorans, das hilft, Atemwegssekrete zu verdünnen und Husten zu lindern.</string>

    <string name="med_name_ibuprofen">Ibuprofen</string>
    <string name="med_desc_ibuprofen">Nichtsteroidales Antirheumatikum (NSAR) – starkes Antipyretikum und Analgetikum.</string>
    <string name="med_warning_ibuprofen">Mit Vorsicht bei Patienten mit Magengeschwüren oder Asthma anwenden. Nicht auf nüchternen Magen einnehmen.</string>

    <string name="med_name_lemsip">Lemsip (Erkältungs-Heißgetränk)</string>
    <string name="med_region_eu_au">In Europa &amp; Australien verbreitet</string>
    <string name="med_desc_lemsip">Heißgetränk mit Paracetamol und Phenylephrin zur Linderung von Grippesymptomen.</string>
    <string name="med_warning_lemsip">Nicht zusammen mit anderen paracetamolhaltigen Medikamenten verwenden.</string>

