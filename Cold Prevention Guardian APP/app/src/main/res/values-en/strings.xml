    <!-- DeepSeek API System Prompt -->
    <string name="deepseek_system_prompt">You are a professional cold prevention assistant. Based on the user\'s information, provide professional advice on symptom analysis, possible causes, precautions, and prevention tips. If medication is involved, emphasize the need to consult a doctor. Please answer in the same language the user is using.</string>

    <!-- Health Assessment Texts -->
    <string name="health_title_normal">Normal Temperature</string>
    <string name="health_analysis_normal">The immune system is in a stable state; no signs of fever detected.</string>
    <string name="health_causes_normal">Current temperature is within the normal range. No need for concern.</string>
    <string name="health_complications_normal">No significant risk of complications.</string>
    <string name="health_advice_normal">Maintain good hygiene, wash hands frequently, and keep warm.</string>

    <string name="health_title_mild">Mildly Elevated Temperature</string>
    <string name="health_analysis_mild">The immune system has initiated a response; slight inflammation may be present.</string>
    <string name="health_causes_mild">May be due to seasonal cold, post-vaccination reaction, or mild infection.</string>
    <string name="health_complications_mild">If left unchecked, temperature may continue to rise.</string>
    <string name="health_advice_mild">Symptomatic intervention is recommended. Rest, drink plenty of water, and monitor temperature closely.</string>

    <string name="health_title_fever">High Fever / Suspected Flu</string>
    <string name="health_analysis_fever">Sudden high fever — the immune system is in a state of active combat.</string>
    <string name="health_causes_fever">Strongly suspect influenza virus or bacterial infection.</string>
    <string name="health_complications_fever">Persistent high fever may lead to dehydration, electrolyte imbalance, or febrile convulsions.</string>
    <string name="health_advice_fever">Do NOT use cold water or alcohol for physical cooling. Drink plenty of warm water. Contact a doctor immediately to evaluate whether antiviral treatment is needed.</string>

    <string name="health_title_emergency">Emergency Hyperpyrexia</string>
    <string name="health_analysis_emergency">Core temperature is significantly elevated; the body is in a high-risk stress state.</string>
    <string name="health_causes_emergency">Severe infection, heat stroke, or other acute pathological factors.</string>
    <string name="health_complications_emergency">Risk of organ damage exists; emergency treatment is required.</string>
    <string name="health_advice_emergency">Seek emergency medical intervention immediately! While waiting for help, keep the patient ventilated and continue monitoring temperature.</string>

    <!-- Medication Texts -->
    <string name="med_name_vitamin_d3">Vitamin D3</string>
    <string name="med_region_global">Globally available</string>
    <string name="med_desc_vitamin_d3">Supports immune system function and reduces the risk of respiratory infections.</string>

    <string name="med_name_echinacea">Echinacea</string>
    <string name="med_region_eu_us">Common in Europe &amp; US</string>
    <string name="med_desc_echinacea">Herbal immune booster that may help shorten the duration of colds.</string>

    <string name="med_name_paracetamol">Paracetamol (Acetaminophen)</string>
    <string name="med_desc_paracetamol">Antipyretic and analgesic used to reduce fever and relieve headache and muscle aches.</string>
    <string name="med_warning_paracetamol">Do not exceed 4 doses in 24 hours. Allow at least 4 hours between doses.</string>

    <string name="med_name_guaifenesin">Guaifenesin</string>
    <string name="med_desc_guaifenesin">Expectorant that helps thin respiratory secretions and relieve cough.</string>

    <string name="med_name_ibuprofen">Ibuprofen</string>
    <string name="med_desc_ibuprofen">Non-steroidal anti-inflammatory drug (NSAID) — strong antipyretic and analgesic.</string>
    <string name="med_warning_ibuprofen">Use with caution in patients with gastric ulcers or asthma. Avoid taking on an empty stomach.</string>

    <string name="med_name_lemsip">Lemsip (Compound Cold Drink)</string>
    <string name="med_region_eu_au">Common in Europe &amp; Australia</string>
    <string name="med_desc_lemsip">Compound hot drink containing paracetamol and phenylephrine to relieve flu symptoms.</string>
    <string name="med_warning_lemsip">Do not use with other medications containing paracetamol.</string>

