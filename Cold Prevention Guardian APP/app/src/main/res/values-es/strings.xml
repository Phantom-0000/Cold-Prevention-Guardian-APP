    <!-- DeepSeek API System Prompt -->
    <string name="deepseek_system_prompt">Eres un asistente profesional de prevención de resfriados. Basándote en la información del usuario, proporciona consejos profesionales sobre análisis de síntomas, posibles causas, precauciones y consejos de prevención. Si se mencionan medicamentos, enfatiza la necesidad de consultar a un médico. Responde en el idioma que el usuario está utilizando.</string>

    <!-- Health Assessment Texts -->
    <string name="health_title_normal">Temperatura normal</string>
    <string name="health_analysis_normal">El sistema inmunológico está en un estado estable; no se detectan signos de fiebre.</string>
    <string name="health_causes_normal">La temperatura actual está dentro del rango normal. No hay motivo de preocupación.</string>
    <string name="health_complications_normal">Sin riesgo significativo de complicaciones.</string>
    <string name="health_advice_normal">Mantén buena higiene, lávate las manos con frecuencia y abrígate.</string>

    <string name="health_title_mild">Temperatura ligeramente elevada</string>
    <string name="health_analysis_mild">El sistema inmunológico ha iniciado una respuesta; puede haber una ligera inflamación.</string>
    <string name="health_causes_mild">Puede deberse a un resfriado estacional, reacción post-vacunación o infección leve.</string>
    <string name="health_complications_mild">Si no se controla, la temperatura puede seguir subiendo.</string>
    <string name="health_advice_mild">Se recomienda intervención sintomática. Descansa, bebe mucha agua y controla la temperatura de cerca.</string>

    <string name="health_title_fever">Fiebre alta / Sospecha de gripe</string>
    <string name="health_analysis_fever">Fiebre alta repentina — el sistema inmunológico está en estado de combate activo.</string>
    <string name="health_causes_fever">Fuerte sospecha de virus de influenza o infección bacteriana.</string>
    <string name="health_complications_fever">La fiebre alta persistente puede provocar deshidratación, desequilibrio electrolítico o convulsiones febriles.</string>
    <string name="health_advice_fever">NO uses agua fría o alcohol para enfriamiento físico. Bebe mucha agua tibia. Contacta a un médico inmediatamente para evaluar si se necesita tratamiento antiviral.</string>

    <string name="health_title_emergency">Hiperpirexia de emergencia</string>
    <string name="health_analysis_emergency">La temperatura central está significativamente elevada; el cuerpo está en un estado de estrés de alto riesgo.</string>
    <string name="health_causes_emergency">Infección grave, golpe de calor u otros factores patológicos agudos.</string>
    <string name="health_complications_emergency">Existe riesgo de daño orgánico; se requiere tratamiento de emergencia.</string>
    <string name="health_advice_emergency">¡Busca intervención médica de emergencia inmediatamente! Mientras esperas ayuda, mantén al paciente ventilado y continúa monitoreando la temperatura.</string>

    <!-- Medication Texts -->
    <string name="med_name_vitamin_d3">Vitamina D3</string>
    <string name="med_region_global">Disponible mundialmente</string>
    <string name="med_desc_vitamin_d3">Apoya la función inmunológica y reduce el riesgo de infecciones respiratorias.</string>

    <string name="med_name_echinacea">Equinácea (Echinacea)</string>
    <string name="med_region_eu_us">Común en Europa y EE.UU.</string>
    <string name="med_desc_echinacea">Reforzador inmunológico a base de hierbas que puede ayudar a acortar la duración de los resfriados.</string>

    <string name="med_name_paracetamol">Paracetamol</string>
    <string name="med_desc_paracetamol">Antipirético y analgésico utilizado para reducir la fiebre y aliviar el dolor de cabeza y dolores musculares.</string>
    <string name="med_warning_paracetamol">No exceder 4 dosis en 24 horas. Dejar al menos 4 horas entre dosis.</string>

    <string name="med_name_guaifenesin">Guaifenesina</string>
    <string name="med_desc_guaifenesin">Expectorante que ayuda a diluir las secreciones respiratorias y aliviar la tos.</string>

    <string name="med_name_ibuprofen">Ibuprofeno</string>
    <string name="med_desc_ibuprofen">Antiinflamatorio no esteroideo (AINE) — antipirético y analgésico potente.</string>
    <string name="med_warning_ibuprofen">Usar con precaución en pacientes con úlceras gástricas o asma. Evitar tomar con el estómago vacío.</string>

    <string name="med_name_lemsip">Lemsip (Bebida caliente compuesta)</string>
    <string name="med_region_eu_au">Común en Europa y Australia</string>
    <string name="med_desc_lemsip">Bebida caliente compuesta que contiene paracetamol y fenilefrina para aliviar los síntomas de la gripe.</string>
    <string name="med_warning_lemsip">No usar con otros medicamentos que contengan paracetamol.</string>

